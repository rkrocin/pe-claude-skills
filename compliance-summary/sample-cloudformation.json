{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Mixed-compliance CloudFormation template for testing the IaC Compliance Reviewer. Contains both compliant and non-compliant resources.",

  "Resources": {

    "EncryptedBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "acme-reports-prod",
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "aws:kms",
                "KMSMasterKeyID": { "Ref": "DataKey" }
              }
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "Tags": [
          { "Key": "Environment", "Value": "production" },
          { "Key": "Application", "Value": "reporting" },
          { "Key": "Owner", "Value": "data-engineering" },
          { "Key": "CostCenter", "Value": "CC-3100" }
        ]
      }
    },

    "UnencryptedBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "acme-temp-uploads"
      }
    },

    "AppDatabase": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceIdentifier": "reporting-db",
        "Engine": "postgres",
        "EngineVersion": "15.4",
        "DBInstanceClass": "db.r4.large",
        "AllocatedStorage": 200,
        "StorageEncrypted": true,
        "KmsKeyId": { "Ref": "DataKey" },
        "PubliclyAccessible": false,
        "MultiAZ": true,
        "MasterUsername": "dbadmin",
        "MasterUserPassword": "ChangeMe123!",
        "Tags": [
          { "Key": "Environment", "Value": "production" },
          { "Key": "Application", "Value": "reporting" },
          { "Key": "Owner", "Value": "data-engineering" }
        ]
      }
    },

    "DataKey": {
      "Type": "AWS::KMS::Key",
      "Properties": {
        "Description": "Encryption key for reporting data",
        "EnableKeyRotation": true,
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowAdmin",
              "Effect": "Allow",
              "Principal": { "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" } },
              "Action": "kms:*",
              "Resource": "*"
            }
          ]
        },
        "Tags": [
          { "Key": "Environment", "Value": "production" },
          { "Key": "Application", "Value": "reporting" },
          { "Key": "Owner", "Value": "data-engineering" },
          { "Key": "CostCenter", "Value": "CC-3100" }
        ]
      }
    },

    "WebSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Web tier security group",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "Tags": [
          { "Key": "Environment", "Value": "production" },
          { "Key": "Application", "Value": "reporting" }
        ]
      }
    }
  }
}
